VITE_TAVILY_API_KEY=

# -------- Backend only (never prefix with VITE_) --------
GROQ_API_KEY=
TAVILY_API_KEY=
SUPABASE_SERVICE_ROLE_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_SECRET=
